---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/layout/Container.astro';
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';
---

<BaseLayout title="Page not found" description="This page does not exist." noindex>
  <Container class="flex min-h-[60vh] flex-col items-start justify-center py-24">
    <Badge tone="amber">404</Badge>
    <h1 class="mt-6 font-editorial text-3xl text-text-primary sm:text-4xl">This route isn't in the manifest.</h1>
    <p class="mt-4 max-w-md leading-relaxed text-text-muted">
      The page you requested doesn't exist, or it moved. Check the URL, or head back to a known-good state.
    </p>
    <div class="mt-8 flex flex-wrap items-center gap-4">
      <Button href="/">Back to homepage</Button>
      <Button href="/install" variant="secondary">Install KubePreflight</Button>
    </div>
  </Container>
</BaseLayout>
