---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/layout/Container.astro';
import Section from '../components/layout/Section.astro';
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import IconLink from '../components/ui/IconLink.astro';
import CodeBlock from '../components/ui/CodeBlock.astro';
import { site } from '../content/site';

const VERSION = site.currentVersion;

const linuxInstall = `VERSION=${VERSION}

curl -LO "https://github.com/imneeteeshyadav98/kubepreflight/releases/download/\${VERSION}/kubepreflight_\${VERSION}_linux_amd64.tar.gz"
curl -LO "https://github.com/imneeteeshyadav98/kubepreflight/releases/download/\${VERSION}/kubepreflight_\${VERSION}_checksums.txt"

grep "kubepreflight_\${VERSION}_linux_amd64.tar.gz" "kubepreflight_\${VERSION}_checksums.txt" | sha256sum -c -

tar -xzf "kubepreflight_\${VERSION}_linux_amd64.tar.gz"
sudo install -m 0755 "kubepreflight_\${VERSION}_linux_amd64/kubepreflight" /usr/local/bin/kubepreflight

kubepreflight --help`;

const macInstall = `VERSION=${VERSION}

curl -LO "https://github.com/imneeteeshyadav98/kubepreflight/releases/download/\${VERSION}/kubepreflight_\${VERSION}_darwin_arm64.tar.gz"
curl -LO "https://github.com/imneeteeshyadav98/kubepreflight/releases/download/\${VERSION}/kubepreflight_\${VERSION}_checksums.txt"

grep "kubepreflight_\${VERSION}_darwin_arm64.tar.gz" "kubepreflight_\${VERSION}_checksums.txt" | shasum -a 256 -c -

tar -xzf "kubepreflight_\${VERSION}_darwin_arm64.tar.gz"
sudo install -m 0755 "kubepreflight_\${VERSION}_darwin_arm64/kubepreflight" /usr/local/bin/kubepreflight

kubepreflight --help`;

const gatekeeperFix = `xattr -d com.apple.quarantine /usr/local/bin/kubepreflight`;

const dockerInstall = `docker pull ghcr.io/imneeteeshyadav98/kubepreflight:${site.currentDockerTag}
docker run --rm ghcr.io/imneeteeshyadav98/kubepreflight:${site.currentDockerTag} --help`;

const checksumVerify = `sha256sum -c kubepreflight_${VERSION}_checksums.txt      # Linux
shasum -a 256 -c kubepreflight_${VERSION}_checksums.txt  # macOS`;

const manifestScan = `# No cluster, no kubeconfig — reads YAML only
$ kubepreflight scan \\
  --manifests-only \\
  --manifests ./k8s \\
  --target-version 1.36`;

const liveScan = `# Requires a working kubeconfig + read-only RBAC (see below)
$ kubectl config current-context
$ kubepreflight scan --target-version 1.36`;

const eksScan = `# Requires kubeconfig + RBAC, plus read-only AWS IAM
$ aws eks update-kubeconfig --name production-eks --region ap-south-1
$ AWS_REGION=ap-south-1 kubepreflight scan \\
  --provider eks \\
  --cluster-name production-eks \\
  --target-version 1.36`;

const trustBoundary = [
  {
    tone: 'signal' as const,
    scan: 'Manifest scan',
    requires: 'Nothing — no cluster, no kubeconfig',
    flag: '--manifests-only'
  },
  {
    tone: 'blue' as const,
    scan: 'Live cluster scan',
    requires: 'A working kubeconfig + read-only Kubernetes RBAC',
    flag: 'default scan'
  },
  {
    tone: 'amber' as const,
    scan: 'EKS rollback assessment',
    requires: 'Kubeconfig + RBAC, plus read-only AWS IAM',
    flag: '--provider eks'
  }
];

const exitCodes = [
  { code: '0', meaning: 'Clean — no blockers or warnings' },
  { code: '1', meaning: 'Warnings only' },
  { code: '2', meaning: 'Blockers found' },
  { code: '3', meaning: 'Incomplete — requested evidence could not be collected' },
  { code: '4', meaning: 'Infrastructure failure — no report was produced at all' }
];
---

<BaseLayout
  title="Install"
  description="Install KubePreflight: verified release binaries, Docker, checksum verification, and the exact permissions a manifest scan, live-cluster scan, and EKS rollback assessment each require."
>
  <Section tone="ink" spacing="md">
    <Container>
      <a href="/" class="text-sm text-text-muted hover:text-text-primary transition-colors duration-150">
        ← Back to home
      </a>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <Badge tone="blue">Installation</Badge>
        <Badge tone="neutral">{VERSION}</Badge>
      </div>

      <h1 class="mt-5 max-w-2xl font-editorial text-4xl leading-[1.12] text-text-primary sm:text-5xl">
        Install KubePreflight.
      </h1>

      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-text-muted">
        A single static binary. No cluster agent, no webhook, no persistent credentials. Every
        command below is pinned to <span class="font-mono text-text-primary">{VERSION}</span> — the
        exact release the EKS case study ran against — not a moving <span class="font-mono">latest</span>
        tag.
      </p>
    </Container>
  </Section>

  <Section tone="ink">
    <Container>
      <div id="binary" class="max-w-2xl">
        <span class="font-mono text-xs uppercase tracking-wide text-text-muted">Get the binary</span>
        <h2 class="mt-3 font-editorial text-3xl text-text-primary sm:text-4xl">Three ways to run it.</h2>
      </div>

      <div class="mt-10 flex flex-col gap-8">
        <div id="linux">
          <h3 class="font-mono text-sm text-text-primary">Linux (amd64)</h3>
          <p class="mt-2 text-sm text-text-muted">
            arm64 uses the same steps — substitute <span class="font-mono">linux_arm64</span> for{' '}
            <span class="font-mono">linux_amd64</span> throughout.
          </p>
          <CodeBlock
            title="terminal"
            code={linuxInstall}
            class="mt-4"
            copyable
            kind="command"
            copyLabel="Copy Linux install command"
          />
        </div>

        <div id="macos">
          <h3 class="font-mono text-sm text-text-primary">macOS (Apple Silicon)</h3>
          <p class="mt-2 text-sm text-text-muted">
            Intel Macs: substitute <span class="font-mono">darwin_amd64</span> for{' '}
            <span class="font-mono">darwin_arm64</span> throughout.
          </p>
          <CodeBlock
            title="terminal"
            code={macInstall}
            class="mt-4"
            copyable
            kind="command"
            copyLabel="Copy macOS install command"
          />
          <p class="mt-3 text-sm text-text-muted">
            If Gatekeeper refuses to run the binary, clear the quarantine attribute rather than
            disabling Gatekeeper system-wide:
          </p>
          <CodeBlock
            title="terminal"
            code={gatekeeperFix}
            class="mt-3"
            copyable
            kind="command"
            copyLabel="Copy Gatekeeper quarantine fix"
          />
        </div>

        <div id="docker">
          <h3 class="font-mono text-sm text-text-primary">Docker</h3>
          <p class="mt-2 text-sm text-text-muted">
            The image is distroless and runs as a fixed non-root user — mount output directories
            with <span class="font-mono">--user "$(id -u):$(id -g)"</span> to avoid permission
            errors.
          </p>
          <CodeBlock
            title="terminal"
            code={dockerInstall}
            class="mt-4"
            copyable
            kind="command"
            copyLabel="Copy Docker install command"
          />
        </div>
      </div>
    </Container>
  </Section>

  <Section tone="ink-raised">
    <Container>
      <div id="checksum" class="max-w-2xl">
        <span class="font-mono text-xs uppercase tracking-wide text-text-muted">Verify the download</span>
        <h2 class="mt-3 font-editorial text-3xl text-text-primary sm:text-4xl">Every release is checksummed.</h2>
        <p class="mt-4 leading-relaxed text-text-muted">
          Every release publishes SHA-256 checksums and an SPDX SBOM. If you downloaded every
          asset into one folder, verify all of them at once:
        </p>
      </div>
      <CodeBlock
        title="terminal"
        code={checksumVerify}
        class="mt-8"
        copyable
        kind="command"
        copyLabel="Copy checksum verification command"
      />
    </Container>
  </Section>

  <Section tone="ink">
    <Container>
      <div class="max-w-2xl">
        <span class="font-mono text-xs uppercase tracking-wide text-text-muted">Trust boundary</span>
        <h2 class="mt-3 font-editorial text-3xl text-text-primary sm:text-4xl">
          Know what you're granting before you run it.
        </h2>
        <p class="mt-4 leading-relaxed text-text-muted">
          KubePreflight is not zero-config where credentials are actually required. Three scan
          types, three different credential requirements:
        </p>
      </div>

      <div class="mt-10 overflow-hidden rounded-[var(--radius-md)] border border-border">
        <div class="overflow-x-auto">
          <table class="w-full border-collapse text-left text-sm">
            <thead>
              <tr class="border-b border-border bg-ink-900">
                <th scope="col" class="px-5 py-3 font-mono text-xs uppercase tracking-wide text-text-muted">Scan type</th>
                <th scope="col" class="px-5 py-3 font-mono text-xs uppercase tracking-wide text-text-muted">Requires</th>
                <th scope="col" class="px-5 py-3 font-mono text-xs uppercase tracking-wide text-text-muted">Flag</th>
              </tr>
            </thead>
            <tbody>
              {
                trustBoundary.map((row, i) => (
                  <tr class={i < trustBoundary.length - 1 ? 'border-b border-border' : ''}>
                    <td class="px-5 py-4 align-top">
                      <Badge tone={row.tone}>{row.scan}</Badge>
                    </td>
                    <td class="break-words px-5 py-4 align-top text-text-muted">{row.requires}</td>
                    <td class="break-words px-5 py-4 align-top font-mono text-xs text-text-primary">{row.flag}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </Container>
  </Section>

  <Section tone="ink-raised">
    <Container>
      <div class="max-w-2xl">
        <span class="font-mono text-xs uppercase tracking-wide text-text-muted">First scan</span>
        <h2 class="mt-3 font-editorial text-3xl text-text-primary sm:text-4xl">Start with the one that needs nothing.</h2>
      </div>

      <div class="mt-10 flex flex-col gap-6">
        <div id="manifest-scan">
          <CodeBlock
            title="manifest scan — no credentials"
            code={manifestScan}
            copyable
            kind="command"
            copyLabel="Copy manifest scan command"
          />
        </div>
        <div id="live-cluster">
          <CodeBlock
            title="live cluster scan — kubeconfig required"
            code={liveScan}
            copyable
            kind="command"
            copyLabel="Copy live cluster scan command"
          />
        </div>
        <div id="eks-scan">
          <p class="mb-2 text-xs text-amber">
            Replace <span class="font-mono">production-eks</span> and{' '}
            <span class="font-mono">ap-south-1</span> with your own cluster name and region before running.
          </p>
          <CodeBlock
            title="EKS scan — kubeconfig + AWS IAM required"
            code={eksScan}
            copyable
            kind="command"
            copyLabel="Copy EKS scan command"
          />
        </div>
      </div>
    </Container>
  </Section>

  <Section tone="ink">
    <Container>
      <div class="max-w-2xl">
        <span class="font-mono text-xs uppercase tracking-wide text-text-muted">Required permissions</span>
        <h2 class="mt-3 font-editorial text-3xl text-text-primary sm:text-4xl">Read-only. Copy-pasteable. Nothing hidden.</h2>
        <p class="mt-4 leading-relaxed text-text-muted">
          KubePreflight never requests <span class="font-mono text-text-primary">secrets</span> access
          and never writes to your cluster or AWS account.
        </p>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-8 md:grid-cols-2">
        <div class="rounded-[var(--radius-md)] border border-border p-8">
          <h3 class="font-mono text-sm text-text-primary">Kubernetes RBAC</h3>
          <p class="mt-3 text-sm leading-relaxed text-text-muted">
            <span class="font-mono">get/list</span> on nodes, pods, PodDisruptionBudgets,
            validating/mutating webhook configurations, services, endpointslices, CRDs,
            deployments, daemonsets — plus one allowlisted <span class="font-mono">get</span> on
            the <span class="font-mono">kube-system/coredns</span> ConfigMap.
          </p>
          <IconLink href={site.clusterRoleUrl} icon="external" external class="mt-5">
            View clusterrole.yaml
          </IconLink>
        </div>
        <div class="rounded-[var(--radius-md)] border border-border p-8">
          <h3 class="font-mono text-sm text-text-primary">AWS IAM (EKS only)</h3>
          <p class="mt-3 text-sm leading-relaxed text-text-muted">
            <span class="font-mono">eks:Describe*</span>/<span class="font-mono">List*</span> for
            cluster, insights, and add-ons, plus{' '}
            <span class="font-mono">ec2:Describe*</span> for subnets, security groups, and VPCs.
            All read-only.
          </p>
          <IconLink href={site.iamPolicyUrl} icon="external" external class="mt-5">
            View iam-policy.json
          </IconLink>
        </div>
      </div>
    </Container>
  </Section>

  <Section tone="paper">
    <Container>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-12">
        <div class="md:col-span-6">
          <span class="font-mono text-xs uppercase tracking-wide text-text-muted-dark">Expected output</span>
          <h2 class="mt-3 font-editorial text-3xl text-text-dark sm:text-4xl">Three files, one verdict.</h2>
          <ul class="mt-6 flex flex-col gap-3 text-sm leading-relaxed text-text-muted-dark">
            <li>
              <span class="font-mono text-text-dark">findings.json</span> — canonical machine-readable
              report, always written
            </li>
            <li>
              <span class="font-mono text-text-dark">report.md</span> — Markdown, with{' '}
              <span class="font-mono">--output=md</span>
            </li>
            <li>
              <span class="font-mono text-text-dark">report.html</span> — self-contained HTML with
              the embedded Console
            </li>
          </ul>
        </div>
        <div class="md:col-span-6">
          <span class="font-mono text-xs uppercase tracking-wide text-text-muted-dark">Exit codes</span>
          <div class="mt-6 overflow-hidden rounded-[var(--radius-md)] border border-border-dark">
            <table class="w-full border-collapse text-left text-sm">
              <tbody>
                {
                  exitCodes.map((row, i) => (
                    <tr class={i < exitCodes.length - 1 ? 'border-b border-border-dark' : ''}>
                      <td class="px-4 py-3 align-top font-mono text-text-dark">{row.code}</td>
                      <td class="break-words px-4 py-3 align-top text-text-muted-dark">{row.meaning}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <Section tone="ink" border={false}>
    <Container>
      <div class="flex flex-col items-start gap-8 md:flex-row md:items-end md:justify-between">
        <div class="max-w-xl">
          <h2 class="font-editorial text-3xl text-text-primary sm:text-4xl">Stuck on something?</h2>
          <p class="mt-4 leading-relaxed text-text-muted">
            Open an issue on GitHub, or wire the same scan into CI so it runs automatically on
            every pull request.
          </p>
        </div>
        <div class="flex flex-wrap items-center gap-x-6 gap-y-4">
          <Button href="/github-action">Set up the GitHub Action</Button>
          <IconLink href={site.issuesUrl} icon="external" external>
            Open an issue
          </IconLink>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>
