---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';
import Section from '../../components/layout/Section.astro';
import Meter from '../../components/ui/Meter.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';
import CodeBlock from '../../components/ui/CodeBlock.astro';
import IconLink from '../../components/ui/IconLink.astro';
import beforeRemediationConsole from '../../assets/case-study/before-remediation-console.png';
import rollbackAssessmentConsole from '../../assets/case-study/rollback-assessment-console.png';

const stats = [
  { label: 'Findings resolved', value: '9' },
  { label: 'Blockers resolved', value: '6' },
  { label: 'New blockers', value: '0' },
  { label: 'Comparison gate', value: 'pass' }
];

const scanScope = ['APIs', 'Webhooks', 'CRDs', 'PodDisruptionBudgets', 'Node compatibility', 'Add-ons', 'Workloads', 'Drain risk'];

const scanCommands = `$ kubepreflight scan --provider eks --cluster-name production --target-version 1.31 --output baseline.json
$ kubepreflight scan --provider eks --cluster-name production --target-version 1.32 --output findings.json`;

const decisionCommands = `$ kubepreflight compare --baseline baseline.json --current findings.json
Readiness score      19 -> 57
Resolved findings    9
Resolved blockers    6
New blockers         0
Comparison gate       pass

$ kubepreflight rollback assess --cluster-name production --region ap-south-1
Rollback eligible     yes
Recommendation        do_not_proceed`;
---

<BaseLayout
  title="EKS 1.31 → 1.32 case study"
  description="Real KubePreflight v0.14.0 evidence from an EKS 1.31 to 1.32 upgrade: readiness moved from 19 to 57, six blockers resolved, zero new blockers, rollback eligible — and a do_not_proceed recommendation."
>
  <Section tone="ink" spacing="md">
    <Container>
      <a href="/" class="text-sm text-text-muted hover:text-text-primary transition-colors duration-150">
        ← Back to home
      </a>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <Badge tone="blue">Case study</Badge>
        <Badge tone="neutral">v0.14.0</Badge>
      </div>

      <h1 class="mt-5 max-w-3xl font-editorial text-4xl leading-[1.12] text-text-primary sm:text-5xl">
        EKS 1.31 → 1.32: from a hard block to a documented decision.
      </h1>

      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-text-muted">
        A real EKS cluster, evaluated end to end with KubePreflight v0.14.0 — before any upgrade
        action was taken. This is the unedited outcome: what changed, what didn't, and why the
        recommendation was still <span class="font-mono text-text-primary">do_not_proceed</span>.
      </p>
    </Container>
  </Section>

  <Section tone="ink">
    <Container>
      <div class="rounded-[var(--radius-md)] border border-border bg-ink-900 p-8 md:p-10">
        <Meter label="Readiness score" value={57} baseline={19} tone="signal" class="max-w-xl" />

        <div class="mt-8 grid grid-cols-2 gap-6 border-t border-border pt-8 sm:grid-cols-4">
          {
            stats.map((stat) => (
              <div>
                <div class="font-mono text-2xl text-text-primary">{stat.value}</div>
                <div class="mt-1 text-xs text-text-muted">{stat.label}</div>
              </div>
            ))
          }
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-3 border-t border-border pt-8">
          <Badge tone="signal">Rollback eligible</Badge>
          <Badge tone="amber">Recommendation: do_not_proceed</Badge>
        </div>
      </div>

      <figure class="mt-10">
        <div class="overflow-hidden rounded-[var(--radius-md)] border border-border">
          <Image
            src={beforeRemediationConsole}
            alt="KubePreflight upgrade readiness report showing a BLOCKED, NO-GO verdict at a readiness score of 19 out of 100, with 7 blockers and 11 warnings, before remediation."
            class="w-full"
            widths={[640, 1024, 1440]}
            sizes="(min-width: 1280px) 1200px, 100vw"
          />
        </div>
        <figcaption class="mt-3 text-sm text-text-muted">
          The baseline scan report — captured during the real EKS 1.31 → 1.32 validation.
          Infrastructure identifiers have been sanitized.
        </figcaption>
      </figure>
    </Container>
  </Section>

  <Section tone="ink-raised">
    <Container>
      <div class="max-w-2xl">
        <span class="font-mono text-xs uppercase tracking-wide text-text-muted">Scope of this scan</span>
        <h2 class="mt-3 font-editorial text-3xl text-text-primary sm:text-4xl">What KubePreflight checked.</h2>
        <p class="mt-4 leading-relaxed text-text-muted">
          Every category below was evaluated against the live cluster and its manifests before the
          baseline-to-target comparison ran.
        </p>
      </div>

      <ul class="mt-10 flex flex-wrap gap-3">
        {
          scanScope.map((item) => (
            <li class="rounded-[var(--radius-sm)] border border-border px-3.5 py-2 font-mono text-xs text-text-muted">
              {item}
            </li>
          ))
        }
      </ul>
    </Container>
  </Section>

  <Section tone="ink">
    <Container>
      <div class="max-w-2xl">
        <span class="font-mono text-xs uppercase tracking-wide text-text-muted">The command sequence</span>
        <h2 class="mt-3 font-editorial text-3xl text-text-primary sm:text-4xl">Two scans, one comparison.</h2>
        <p class="mt-4 leading-relaxed text-text-muted">
          A baseline scan at the current version, a second scan against the target version, then a
          comparison — the same sequence a CI gate runs automatically.
        </p>
      </div>

      <div class="mt-10 flex flex-col gap-6">
        <CodeBlock title="1–2. establish baseline and target scans" code={scanCommands} />
        <CodeBlock title="3–4. compare and assess rollback" code={decisionCommands} />
      </div>
    </Container>
  </Section>

  <Section tone="paper">
    <Container>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-12">
        <div class="md:col-span-7">
          <span class="font-mono text-xs uppercase tracking-wide text-text-muted-dark">The decision</span>
          <h2 class="mt-3 font-editorial text-3xl text-text-dark sm:text-4xl">
            Eligible to roll back. Not clear to proceed.
          </h2>
          <blockquote class="mt-6 border-l-2 border-signal-dim pl-5 font-editorial text-xl leading-snug text-text-dark">
            EKS technically allowed rollback, but the operational evidence did not support
            proceeding.
          </blockquote>
          <p class="mt-6 max-w-xl leading-relaxed text-text-muted-dark">
            Rollback eligibility answers one question: can you go back if this fails? It does not
            answer whether you should go forward. Six blockers were resolved and zero new ones
            appeared — real progress — but the remaining findings were enough to keep the
            recommendation at <span class="font-mono text-text-dark">do_not_proceed</span>.
          </p>
        </div>

        <div class="md:col-span-5">
          <figure>
            <div class="overflow-hidden rounded-[var(--radius-md)] border border-border-dark">
              <Image
                src={rollbackAssessmentConsole}
                alt="KubePreflight rollback readiness report showing eligibility as eligible, readiness as blocked, and a recommendation of do not proceed."
                class="w-full"
                widths={[480, 720]}
                sizes="(min-width: 768px) 420px, 100vw"
              />
            </div>
            <figcaption class="mt-3 text-sm text-text-muted-dark">
              The rollback assessment — same cluster, same scan. Infrastructure identifiers have
              been sanitized.
            </figcaption>
          </figure>
        </div>
      </div>
    </Container>
  </Section>

  <Section tone="ink" border={false}>
    <Container>
      <div class="flex flex-col items-start gap-8 md:flex-row md:items-end md:justify-between">
        <div class="max-w-xl">
          <h2 class="font-editorial text-3xl text-text-primary sm:text-4xl">Run this against your own cluster.</h2>
          <p class="mt-4 leading-relaxed text-text-muted">
            The same scan and comparison sequence, on a real EKS cluster, took minutes — not a
            change-freeze.
          </p>
        </div>
        <div class="flex flex-wrap items-center gap-x-6 gap-y-4">
          <Button href="/install">Run your first scan</Button>
          <IconLink href="/github-action">See how the gate works in CI</IconLink>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>
