---
// Renders pre-formatted command/output text as framed "product evidence."
// Lines starting with "$ " are treated as prompts, "#" as comments — both
// styled at build time, no client JS or syntax-highlighter dependency.
interface Props {
  title?: string;
  code: string;
  class?: string;
  copyable?: boolean;
  copyLabel?: string;
  kind?: 'command' | 'output';
}

const { title, code, class: className = '', copyable = false, copyLabel, kind } = Astro.props;

const lines = code.replace(/^\n/, '').replace(/\n$/, '').split('\n');

function escapeHtml(value: string): string {
  return value.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

const highlighted = lines
  .map((line) => {
    const isPrompt = line.startsWith('$ ');
    const isComment = line.trimStart().startsWith('#');
    const cls = isPrompt ? 'text-signal' : isComment ? 'text-text-muted' : 'text-text-primary';
    return `<span class="${cls}">${escapeHtml(line)}</span>`;
  })
  .join('\n');

// What actually lands on the clipboard: strip the "$ " prompt marker so a
// paste runs directly in a shell instead of erroring on a literal "$ ".
const copyText = lines.map((line) => (line.startsWith('$ ') ? line.slice(2) : line)).join('\n');

const defaultCopyLabel = copyLabel ?? `Copy ${title ?? 'command'}`;

const kindLabel: Record<NonNullable<Props['kind']>, string> = {
  command: 'Command',
  output: 'Expected output'
};
---

<div class={`overflow-hidden rounded-[var(--radius-md)] border border-border bg-ink-900 ${className}`}>
  {
    (title || kind || copyable) && (
      <div class="flex items-center gap-2 border-b border-border px-4 py-2.5">
        <span class="h-2 w-2 shrink-0 rounded-full bg-border-strong" aria-hidden="true" />
        {title && <span class="truncate font-mono text-xs text-text-muted">{title}</span>}
        {
          kind && (
            <span class="shrink-0 rounded-[var(--radius-xs)] border border-border px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-wider text-text-muted">
              {kindLabel[kind]}
            </span>
          )
        }
        <span class="flex-1" />
        {
          copyable && (
            <span class="relative shrink-0">
              <button
                type="button"
                class="copy-button flex min-h-11 min-w-11 items-center justify-center gap-1.5 rounded-[var(--radius-sm)] border border-border px-2.5 text-xs text-text-muted transition-colors duration-150 hover:border-signal hover:text-signal"
                aria-label={defaultCopyLabel}
                data-copy-text={copyText}
                data-default-label="Copy"
              >
                <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <rect x="5.5" y="5.5" width="8" height="8" rx="1.2" stroke="currentColor" stroke-width="1.3" />
                  <path
                    d="M3.5 10.5h-1a1 1 0 0 1-1-1v-7a1 1 0 0 1 1-1h7a1 1 0 0 1 1 1v1"
                    stroke="currentColor"
                    stroke-width="1.3"
                  />
                </svg>
                <span class="copy-button-label">Copy</span>
              </button>
              <span class="sr-only" aria-live="polite" data-copy-status />
            </span>
          )
        }
      </div>
    )
  }
  <pre class="overflow-x-auto px-4 py-4 text-[13px] leading-relaxed"><code class="font-mono" set:html={highlighted} /></pre>
</div>

<script>
  document.addEventListener('click', async (event) => {
    const button = (event.target as HTMLElement)?.closest<HTMLButtonElement>('.copy-button');
    if (!button) return;

    const text = button.dataset.copyText ?? '';
    const defaultLabel = button.dataset.defaultLabel ?? 'Copy';
    const labelEl = button.querySelector<HTMLElement>('.copy-button-label');
    const statusEl = button.parentElement?.querySelector<HTMLElement>('[data-copy-status]');

    async function copy(value: string) {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(value);
        return;
      }
      // Fallback for browsers without the async Clipboard API.
      const textarea = document.createElement('textarea');
      textarea.value = value;
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      // Deprecated, but still the only fallback when the async Clipboard API
      // is unavailable (older browsers, non-secure contexts).
      const ok = document.execCommand('copy');
      textarea.remove();
      if (!ok) throw new Error('execCommand copy failed');
    }

    let resultLabel: string;
    try {
      await copy(text);
      resultLabel = 'Copied';
      if (statusEl) statusEl.textContent = 'Copied to clipboard';
    } catch {
      resultLabel = 'Copy failed';
      if (statusEl) statusEl.textContent = 'Copy failed. Select the text and copy it manually.';
    }

    if (labelEl) labelEl.textContent = resultLabel;
    window.clearTimeout(Number(button.dataset.resetTimer));
    const timer = window.setTimeout(() => {
      if (labelEl) labelEl.textContent = defaultLabel;
    }, 2000);
    button.dataset.resetTimer = String(timer);
  });
</script>
