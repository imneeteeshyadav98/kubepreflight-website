---
import Container from '../layout/Container.astro';
import CodeBlock from '../ui/CodeBlock.astro';
import IconLink from '../ui/IconLink.astro';

const proofCode = `$ kubepreflight compare --baseline 1.31 --target 1.32
# real evidence, v0.14.0 — see full case study for context
Readiness score      19 -> 57
Findings resolved    9
Blockers resolved    6
New blockers         0
Rollback eligible     yes
Recommendation        do_not_proceed`;
---

<Container class="py-20 md:py-24">
  <div class="grid grid-cols-1 gap-12 md:grid-cols-12 md:items-start">
    <div class="md:col-span-5">
      <h2 class="font-editorial text-2xl text-text-primary sm:text-3xl">Not a linter. A readiness signal.</h2>
      <p class="mt-4 leading-relaxed text-text-muted">
        Every run produces a comparable readiness score, a list of resolved and new blockers, and
        an explicit go / no-go recommendation — evidence you can attach to a change ticket, not a
        pass/fail guess.
      </p>
      <IconLink href="/case-study/eks-1-31-to-1-32" class="mt-6">
        Read the full EKS 1.31 → 1.32 case study
      </IconLink>
    </div>
    <div class="md:col-span-7">
      <CodeBlock title="kubepreflight compare" code={proofCode} />
    </div>
  </div>
</Container>
