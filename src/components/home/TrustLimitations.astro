---
import Container from '../layout/Container.astro';
import Section from '../layout/Section.astro';

const limitations = [
  {
    title: 'Advisory, not enforcement',
    description: 'KubePreflight recommends a go / no-go decision. It does not block kubectl apply or modify your cluster.'
  },
  {
    title: 'Read access is enough — and required',
    description: 'Scans need read access to workloads and, for EKS, the control plane version. No write access is ever requested.'
  },
  {
    title: 'Rollback eligibility is a check, not a guarantee',
    description: 'The rollback assessment reflects EKS-reported version and node group compatibility at scan time, not a rehearsed rollback.'
  }
];
---

<Section tone="paper">
  <Container>
    <div class="max-w-2xl">
      <span class="font-mono text-xs uppercase tracking-wide text-text-muted-dark">Where to stay careful</span>
      <h2 class="mt-3 font-editorial text-3xl text-text-dark sm:text-4xl">What KubePreflight doesn't claim.</h2>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-10 md:grid-cols-3">
      {
        limitations.map((item) => (
          <div class="border-t border-border-dark pt-6">
            <h3 class="text-base font-medium text-text-dark">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-muted-dark">{item.description}</p>
          </div>
        ))
      }
    </div>
  </Container>
</Section>
