---
import Container from '../layout/Container.astro';
import Section from '../layout/Section.astro';
import IconLink from '../ui/IconLink.astro';
const layers = [
  {
    index: '01',
    title: 'Upgrade readiness scoring',
    description:
      'Scans manifests and live cluster state against the target Kubernetes version — deprecated APIs, removed fields, webhook compatibility — into one comparable score.',
    href: '/eks-upgrade-readiness',
    linkLabel: 'Read the EKS readiness guide',
    external: false
  },
  {
    index: '02',
    title: 'EKS rollback assessment',
    description:
      'Assesses rollback posture before you upgrade — control-plane rollback prerequisites, version skew, and node group compatibility. Re-verify live eligibility closer to the maintenance window, since conditions can shift.',
    href: '/case-study/eks-1-31-to-1-32',
    linkLabel: 'Read the rollback evidence',
    external: false
  },
  {
    index: '03',
    title: 'Context-aware upgrade gating',
    description:
      'Evaluates control-plane upgrades, worker rollouts, full-platform upgrades, workload restarts, audit-only assessments, and unspecified reviews separately.',
    href: '/docs#upgrade-context',
    linkLabel: 'Choose an upgrade context',
    external: false
  },
  {
    index: '04',
    title: 'CI regression gate',
    description:
      'Wire the same evaluation into pull requests. Block merges when readiness regresses, with the score and blockers posted directly on the check.',
    href: '/github-action',
    linkLabel: 'View the GitHub Action',
    external: false
  }
];
---

<Section tone="ink-raised">
  <Container>
    <div class="max-w-2xl">
      <span class="font-mono text-xs uppercase tracking-wide text-text-muted">What it evaluates</span>
      <h2 class="mt-3 font-editorial text-3xl text-text-primary sm:text-4xl">Three evidence layers. One reviewable decision.</h2>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-px overflow-hidden rounded-[var(--radius-md)] border border-border bg-border md:grid-cols-2 lg:grid-cols-4">
      {
        layers.map((layer) => (
          <div class="flex flex-col bg-ink-950 p-8">
            <span class="font-mono text-sm text-signal">{layer.index}</span>
            <h3 class="mt-4 font-editorial text-xl text-text-primary">{layer.title}</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted">{layer.description}</p>
            <IconLink href={layer.href} external={layer.external} class="mt-6">
              {layer.linkLabel}
            </IconLink>
          </div>
        ))
      }
    </div>
  </Container>
</Section>
