---
import Container from '../layout/Container.astro';
import Section from '../layout/Section.astro';
import Button from '../ui/Button.astro';
import IconLink from '../ui/IconLink.astro';
import { site } from '../../content/site';
---

<Section tone="ink" border={false}>
  <Container>
    <div class="flex flex-col items-start gap-8 md:flex-row md:items-end md:justify-between">
      <div class="max-w-xl">
        <h2 class="font-editorial text-3xl text-text-primary sm:text-4xl">Know before you upgrade.</h2>
        <p class="mt-4 leading-relaxed text-text-muted">
          Run it against a real cluster or a manifest directory — the first scan takes minutes,
          not a change-freeze.
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-x-6 gap-y-4">
        <Button href="/install">Run your first scan</Button>
        <IconLink href="/docs">Read the docs journey</IconLink>
        <IconLink href={site.githubUrl} icon="github" external>
          GitHub
        </IconLink>
      </div>
    </div>
  </Container>
</Section>
