---
import Container from '../layout/Container.astro';
import Button from '../ui/Button.astro';
import IconLink from '../ui/IconLink.astro';
import Badge from '../ui/Badge.astro';
import { site } from '../../content/site';
---

<div class="border-b border-border">
  <Container class="grid grid-cols-1 gap-16 py-24 md:grid-cols-12 md:py-32">
    <div class="md:col-span-8">
      <Badge tone="signal">v0.14.0 &middot; verified against real EKS upgrades</Badge>

      <h1 class="mt-6 font-editorial text-4xl leading-[1.12] text-text-primary sm:text-5xl lg:text-[3.5rem]">
        Upgrade Kubernetes<br />with evidence, not assumptions.
      </h1>

      <p class="mt-6 max-w-xl text-lg leading-relaxed text-text-muted">
        {site.description}
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-4">
        <Button href="/install">Run your first scan</Button>
        <Button href="/case-study/eks-1-31-to-1-32" variant="secondary">View real EKS case study</Button>
        <IconLink href={site.githubUrl} icon="github" external>
          GitHub
        </IconLink>
      </div>
    </div>
  </Container>
</div>
