---
import Container from '../layout/Container.astro';
import Section from '../layout/Section.astro';
import CodeBlock from '../ui/CodeBlock.astro';
import Button from '../ui/Button.astro';

const installCode = `# after installing (see options below)
$ kubepreflight scan --context <your-context> --target-version 1.32`;
---

<Section tone="ink">
  <Container>
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12 md:items-center">
      <div class="md:col-span-5">
        <span class="font-mono text-xs uppercase tracking-wide text-text-muted">Installation</span>
        <h2 class="mt-3 font-editorial text-3xl text-text-primary sm:text-4xl">Running in under a minute.</h2>
        <p class="mt-4 leading-relaxed text-text-muted">
          A single static binary. No cluster agent, no webhook to install, no persistent
          credentials left behind.
        </p>
        <Button href="/install" class="mt-8">See all install options</Button>
      </div>

      <div class="md:col-span-7">
        <CodeBlock title="terminal" code={installCode} />
      </div>
    </div>
  </Container>
</Section>
