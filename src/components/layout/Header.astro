---
import Container from './Container.astro';
import Logo from '../brand/Logo.astro';
import Button from '../ui/Button.astro';
import IconLink from '../ui/IconLink.astro';
import { primaryNav } from '../../content/navigation';
import { site } from '../../content/site';

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  return href === '/' ? currentPath === '/' : currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 border-b border-border bg-ink-950/95 backdrop-blur supports-[backdrop-filter]:bg-ink-950/80">
  <Container as="nav" class="flex h-16 items-center justify-between" aria-label="Primary">
    <Logo />

    <ul class="hidden items-center gap-8 lg:flex">
      {
        primaryNav.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
              class={`text-sm transition-colors duration-150 ${
                isActive(item.href) ? 'text-text-primary' : 'text-text-muted hover:text-text-primary'
              }`}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="hidden items-center gap-6 lg:flex">
      <IconLink href={site.githubUrl} icon="github" external class="text-text-muted hover:text-text-primary">
        <span class="sr-only">GitHub</span>
      </IconLink>
      <Button href="/install" size="sm">Run your first scan</Button>
    </div>

    <details class="relative lg:hidden">
      <summary
        class="flex h-9 w-9 cursor-pointer list-none items-center justify-center rounded-[var(--radius-sm)] border border-border text-text-primary [&::-webkit-details-marker]:hidden"
        aria-label="Open menu"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M2 5h14M2 9h14M2 13h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </summary>

      <div class="absolute right-0 top-full mt-3 w-64 rounded-[var(--radius-md)] border border-border bg-ink-900 p-5 shadow-xl">
        <ul class="flex flex-col gap-4">
          {
            primaryNav.map((item) => (
              <li>
                <a href={item.href} class="block text-sm text-text-primary">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
        <div class="mt-5 flex flex-col gap-3 border-t border-border pt-5">
          <IconLink href={site.githubUrl} icon="github" external>
            GitHub
          </IconLink>
          <Button href="/install" size="sm" class="w-full">Run your first scan</Button>
        </div>
      </div>
    </details>
  </Container>
</header>
