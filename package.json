{
  "name": "kubepreflight-website",
  "type": "module",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/imneeteeshyadav98/kubepreflight-website.git"
  },
  "homepage": "https://kubepreflight.com",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "check:browser": "node scripts/browser-smoke.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check:content": "node scripts/check-content.mjs",
    "check:lighthouse": "node scripts/check-lighthouse.mjs",
    "test:lighthouse-seo-exception": "node scripts/check-lighthouse-exception.test.mjs",
    "build": "astro build",
    "clean": "node scripts/clean-build.mjs",
    "verify": "npm run check && npm run check:content && npm run test:lighthouse-seo-exception && npm run build && npm run check:links",
    "build:prod": "npm run clean && npm run verify",
    "preview": "astro preview",
    "preview:prod": "astro preview --host 127.0.0.1 --port 4322",
    "prod": "npm run build:prod && npm run preview:prod",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.0",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^12.8.2",
    "typescript": "^6.0.3"
  }
}
