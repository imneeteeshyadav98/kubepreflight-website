# Copy to .env to override locally. In production this is set as a GitHub
# Actions repository Variable (Settings -> Secrets and variables -> Actions ->
# Variables -> KUBEPREFLIGHT_VERSION) and passed into the build step in
# .github/workflows/deploy.yml — bumping a release is then just updating that
# variable and re-running the deploy workflow, no source change required.
#
# Not sensitive: this value is already publicly visible in every install
# command the built site renders. It's a GitHub Actions Variable, not a
# Secret, on purpose.

PUBLIC_KUBEPREFLIGHT_VERSION=v0.14.0
